<header class="site-header" role="banner">
  <div class="container">
    <div class="site-header__inner">
      <a class="brand" href="{{ routes.root_url }}">
        <span class="brand__mark" aria-hidden="true"></span>
        <span class="brand__name">{{ settings.brand_name | default: shop.name }}</span>
      </a>

      <nav class="nav" aria-label="Primary">
        {% if settings.main_menu != blank %}
          {% for link in linklists[settings.main_menu].links %}
            <a href="{{ link.url }}">{{ link.title }}</a>
          {% endfor %}
        {% else %}
          <a href="{{ routes.all_products_collection_url }}">Catalog</a>
        {% endif %}
      </nav>

      <div class="header-actions">
        <a class="icon-btn" href="{{ routes.cart_url }}" aria-label="{{ 'cart.title' | t }}">
          {% render 'icon-cart' %}
          <span class="visually-hidden">{{ 'cart.title' | t }}</span>
          <span class="badge" data-cart-count>{{ cart.item_count }}</span>
        </a>

        {% if settings.enable_cart_drawer %}
          <button class="icon-btn" type="button" data-drawer-open aria-label="{{ 'cart.title' | t }}">
            {% render 'icon-menu' %}
          </button>
        {% endif %}
      </div>
    </div>
  </div>

  {% if settings.enable_cart_drawer %}
    <div class="drawer-backdrop" data-drawer-backdrop></div>
    <aside class="drawer" data-drawer aria-hidden="true" aria-label="{{ 'cart.title' | t }}">
      <div class="drawer__head">
        <strong>{{ 'cart.title' | t }}</strong>
        <button class="icon-btn" type="button" data-drawer-close aria-label="{{ 'general.close' | t }}">
          <span aria-hidden="true">✕</span>
        </button>
      </div>
      <div class="drawer__body">
        {% render 'cart-mini' %}
      </div>
      <div class="drawer__foot">
        <a class="btn btn--ghost" href="{{ routes.cart_url }}">{{ 'cart.view_cart' | t }}</a>
        <a class="btn btn--primary" href="{{ routes.checkout_url }}">{{ 'cart.checkout' | t }}</a>
      </div>
    </aside>
  {% endif %}
</header>

{% schema %}
{
  "name": "Header",
  "settings": []
}
{% endschema %}

