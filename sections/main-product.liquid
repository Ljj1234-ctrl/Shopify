{%- assign p = product -%}

<section class="container">
  <div class="grid" style="grid-template-columns:1.05fr .95fr;gap:18px">
    <div class="stack" style="gap:12px">
      <div class="media-gallery" data-gallery>
        <div class="card" data-gallery-main style="overflow:hidden;border-radius:18px">
          {%- if p.featured_image -%}
            <img class="img-fit" src="{{ p.featured_image | image_url: width: 1400 }}" alt="{{ p.featured_image.alt | escape }}">
          {%- endif -%}
        </div>

        {%- if p.images.size > 1 -%}
          <div class="thumbs" aria-label="Gallery thumbnails">
            {%- for image in p.images limit: 10 -%}
              <button
                class="thumb"
                type="button"
                data-gallery-thumb
                data-src="{{ image | image_url: width: 1400 }}"
                aria-current="{% if forloop.first %}true{% else %}false{% endif %}"
              >
                <img class="img-fit" src="{{ image | image_url: width: 240 }}" alt="{{ image.alt | escape }}" loading="lazy">
              </button>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
    </div>

    <div class="stack" style="gap:14px">
      <div class="stack" style="gap:8px">
        <h1 style="margin:0">{{ p.title }}</h1>
        {% render 'price', product: p %}
        {%- if p.description != blank -%}
          <div class="muted" style="line-height:1.6">{{ p.description }}</div>
        {%- endif -%}
      </div>

      <div class="card">
        <div class="card__pad stack" style="gap:12px">
          <form method="post" action="/cart/add" id="product-form-{{ section.id }}">
            <input type="hidden" name="id" value="{{ p.selected_or_first_available_variant.id }}">

            {%- if p.variants.size > 1 -%}
              <label style="display:block;font-weight:600;margin-bottom:6px">Variant</label>
              <select class="input" name="id">
                {%- for v in p.variants -%}
                  <option value="{{ v.id }}" {% if v.id == p.selected_or_first_available_variant.id %}selected{% endif %} {% unless v.available %}disabled{% endunless %}>
                    {{ v.title }}{% unless v.available %} — {{ 'product.sold_out' | t }}{% endunless %}
                  </option>
                {%- endfor -%}
              </select>
            {%- endif -%}

            <div class="row" style="gap:10px;align-items:flex-end">
              <div style="flex:1">
                <label style="display:block;font-weight:600;margin-bottom:6px">{{ 'product.quantity' | t }}</label>
                <input class="input" type="number" name="quantity" min="1" value="1">
              </div>
              <button
                class="btn btn--accent"
                type="submit"
                style="flex:1"
                data-loading-label="Adding…"
                {% unless p.available %}disabled{% endunless %}
              >
                {%- if p.available -%}{{ 'product.add_to_cart' | t }}{%- else -%}{{ 'product.sold_out' | t }}{%- endif -%}
              </button>
            </div>
          </form>
        </div>
      </div>

      <div class="card">
        <div class="card__pad stack" style="gap:8px">
          <div class="muted">Shipping, returns, and trust badges can go here.</div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @media (max-width: 900px){
    .grid[style*="grid-template-columns"]{grid-template-columns:1fr !important}
  }
</style>

{% schema %}
{
  "name": "Main product",
  "settings": []
}
{% endschema %}

