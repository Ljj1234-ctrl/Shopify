<section class="container stack" style="gap:16px">
  <div class="row between center wrap">
    <h1 style="margin:0">{{ 'cart.title' | t }}</h1>
    <div class="muted">{{ cart.item_count }} items</div>
  </div>

  {%- if cart.item_count == 0 -%}
    <div class="card"><div class="card__pad muted">{{ 'cart.empty' | t }}</div></div>
    <a class="btn btn--primary" href="{{ routes.all_products_collection_url }}">Continue shopping</a>
  {%- else -%}
    <form action="{{ routes.cart_url }}" method="post" novalidate class="stack" style="gap:14px">
      <div class="stack" style="gap:12px">
        {%- for item in cart.items -%}
          <div class="card">
            <div class="card__pad">
              <div class="row" style="align-items:flex-start">
                <div style="width:110px;flex:0 0 auto">
                  {%- if item.image -%}
                    <a href="{{ item.url }}">
                      <img class="card" src="{{ item.image | image_url: width: 240 }}" alt="{{ item.image.alt | escape }}" loading="lazy" style="border-radius:14px">
                    </a>
                  {%- endif -%}
                </div>
                <div class="stack" style="gap:8px;flex:1">
                  <div class="row between" style="gap:10px;align-items:flex-start">
                    <div class="stack" style="gap:4px">
                      <a href="{{ item.url }}" style="font-weight:700">{{ item.product.title }}</a>
                      <div class="muted" style="font-size:14px">
                        {%- if item.variant.title != 'Default Title' -%}{{ item.variant.title }}{%- endif -%}
                      </div>
                    </div>
                    <div style="font-weight:800">{{ item.final_line_price | money }}</div>
                  </div>

                  <div class="row wrap center" style="align-items:flex-end">
                    <div style="width:160px">
                      <label class="muted" style="display:block;font-size:14px;margin-bottom:6px">{{ 'product.quantity' | t }}</label>
                      <input class="input" type="number" name="updates[]" value="{{ item.quantity }}" min="0" inputmode="numeric">
                    </div>
                    <div class="row wrap" style="gap:10px;align-items:center">
                      <a class="btn btn--ghost" href="{{ routes.cart_change_url }}?line={{ forloop.index }}&quantity=0">Remove</a>
                      <span class="muted" style="font-size:14px">Line: {{ item.final_price | money }}</span>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        {%- endfor -%}
      </div>

      <div class="card">
        <div class="card__pad stack" style="gap:12px">
          <div class="row between center">
            <span class="muted">{{ 'cart.subtotal' | t }}</span>
            <strong style="font-size:18px">{{ cart.total_price | money }}</strong>
          </div>
          <div class="row wrap" style="gap:10px">
            <button class="btn" type="submit" name="update">Update cart</button>
            <button class="btn btn--primary" type="submit" name="checkout">{{ 'cart.checkout' | t }}</button>
          </div>
        </div>
      </div>
    </form>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Main cart",
  "settings": []
}
{% endschema %}

