{%- if cart.item_count == 0 -%}
  <p class="muted">{{ 'cart.empty' | t }}</p>
{%- else -%}
  <div class="stack" style="gap:12px">
    {%- for item in cart.items -%}
      <div class="row" style="gap:12px;align-items:flex-start">
        <div style="width:72px;flex:0 0 auto">
          {%- if item.image -%}
            <a href="{{ item.url }}">
              <img class="card" src="{{ item.image | image_url: width: 180 }}" alt="{{ item.image.alt | escape }}" loading="lazy" style="border-radius:14px">
            </a>
          {%- endif -%}
        </div>
        <div class="stack" style="gap:6px;flex:1">
          <a href="{{ item.url }}" style="font-weight:600">{{ item.product.title }}</a>
          <div class="muted" style="font-size:14px">
            {%- if item.variant.title != 'Default Title' -%}{{ item.variant.title }} · {% endif -%}
            Qty {{ item.quantity }}
          </div>
          <div style="font-weight:700">{{ item.final_line_price | money }}</div>
        </div>
      </div>
    {%- endfor -%}

    <div class="row between center" style="border-top:1px solid var(--color-border);padding-top:12px">
      <span class="muted">{{ 'cart.subtotal' | t }}</span>
      <strong>{{ cart.total_price | money }}</strong>
    </div>
  </div>
{%- endif -%}

